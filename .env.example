# ============================================================
# Plastic Promise environment example
# Copy to .env and adjust for the local machine.
# ============================================================

# ---- Storage paths ----
PLASTIC_DB_PATH=data/db/plastic_memory.db
PLASTIC_LANCEDB_PATH=data/lancedb

# ---- Embeddings ----
# Default local path: Ollama mxbai-embed-large (1024 dimensions).
EMBEDDER_PROVIDER=ollama
EMBEDDER_MODEL=mxbai-embed-large
PP_EMBEDDING_DIM=1024
OLLAMA_HOST=http://127.0.0.1:11434

# Optional structure-aware chunking and local semantic enrichment.
# Enrichment requires structure-v1. Keep it off for latency-sensitive writes;
# use shadow for bounded background validation; activate on with an offline
# rebuild, then keep it enabled for matching writes and repairs.
PP_MEMORY_CHUNKING=off
PP_MEMORY_CHUNK_ENRICHMENT=off
PP_MEMORY_CHUNK_ENRICHMENT_MODEL=qwen3:8b
# Optional: pin the exact Ollama model digest; otherwise it is resolved from /api/tags.
# PP_MEMORY_CHUNK_ENRICHMENT_MODEL_DIGEST=sha256:...
# PP_MEMORY_CHUNK_ENRICHMENT_TIMEOUT=45
# PP_MEMORY_CHUNK_ENRICHMENT_QUEUE_SIZE=32
# PP_MEMORY_CHUNK_ENRICHMENT_CACHE_PATH=data/db/semantic_chunk_enrichment.db

# Optional hosted embedding provider. Enable explicitly if needed.
# EMBEDDER_PROVIDER=openai
# EMBEDDER_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-...

# ---- Reranking ----
# Local-first by default. Hosted rerankers require explicit opt-in.
PP_RERANK_PROVIDERS=ollama,cosine
# PP_RERANK_PROVIDERS=jina,siliconflow,ollama,cosine
# JINA_API_KEY=
# SILICONFLOW_API_KEY=

# ---- Trust system ----
PP_TRUST_INITIAL=0.60
PP_TRUST_MIN=0.10
PP_TRUST_MAX=1.00

# ---- Audit ----
PP_AUDIT_PRE_CHECK_ENABLED=true
PP_AUDIT_LOG_PATH=data/audit.log

# ---- Runtime ----
PP_RUST_ENGINE=auto
PP_LOG_LEVEL=INFO

# ---- Agent owner ----
# Used to isolate memories in multi-agent setups.
# AGENT_OWNER=main-dev
