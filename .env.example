# ============================================================
# Plastic Promise — 环境变量示例
# ============================================================
# 复制为 .env 并按实际环境修改；或在启动前 set 到 shell
# ============================================================

# ---- 存储路径 ----
PP_LANCEDB_PATH=.data/lancedb
PP_SQLITE_PATH=.data/memories.db

# ---- 嵌入 ----
# 默认用 sentence-transformers all-MiniLM-L6-v2 (384)
PP_EMBEDDING_BACKEND=sentence-transformers
PP_EMBEDDING_MODEL=all-MiniLM-L6-v2
PP_EMBEDDING_DIM=384
# 也可用 OpenAI:
# PP_EMBEDDING_BACKEND=openai
# OPENAI_API_KEY=sk-...

# ---- 信任系统 ----
PP_TRUST_INITIAL=0.60
PP_TRUST_MIN=0.10
PP_TRUST_MAX=1.00

# ---- 审计 ----
PP_AUDIT_PRE_CHECK_ENABLED=true
PP_AUDIT_LOG_PATH=.data/audit.log

# ---- 日志 ----
PP_LOG_LEVEL=INFO

# ---- Agent Owner (用于多 Agent 场景) ----
# AGENT_OWNER=main-dev
